package com.example.mymod;

import com.mojang.blaze3d.vertex.PoseStack;
import net.minecraft.world.InteractionHand;
import net.minecraft.world.item.ItemStack;
import net.neoforged.bus.api.SubscribeEvent;
import net.neoforged.neoforge.client.event.RenderHandEvent;

public class MyLeftHand {
    // Выделенные независимые координаты левой руки
    public static float leftY = 0.10f;
    public static float leftZ = -0.45f;

    @SubscribeEvent
    public void onRenderLeftHand(RenderHandEvent event) {
        if (event.getHand() != InteractionHand.OFF_HAND) return;

        ItemStack itemStack = event.getItemStack();
        if (itemStack.isEmpty()) return;

        String itemName = itemStack.getItem().toString().toLowerCase();
        if (itemName.contains("sword") || itemName.contains("axe") || itemName.contains("pickaxe")) {
            PoseStack poseStack = event.getPoseStack();
            
            // УМЕНЬШЕНО В 2 РАЗА: 0.275f вместо 0.55f
            poseStack.scale(0.275f, 0.275f, 0.275f);
            
            // Смещение (X зафиксирован для левой стороны, Y и Z управляются кнопками)
            poseStack.translate(-0.24D, (double)leftY, (double)leftZ);
        }
    }
}
